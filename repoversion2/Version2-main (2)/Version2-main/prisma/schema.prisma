// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model SystemSettings {
  id                    String        @id @default("global")
  stripeSecretKey       String?       // Encrypted in production
  stripeWebhookSecret   String?       // Encrypted in production
  databaseUrl           String?       // Encrypted in production
  lockoutDurationDays   Int           @default(7)
  platformCommission    Float         @default(10.0) // Percentage
  
  updatedAt             DateTime      @updatedAt
}

model Company {
  id                    String        @id @default(uuid())
  name                  String
  email                 String        @unique
  stripeAccountId       String?       @unique
  stripeOnboardingComplete Boolean    @default(false)
  taxVerified           Boolean       @default(false)
  kycLevel              Int           @default(0) // 0: None, 1: Personal, 2: Business
  rating                Float?        @default(5.0)
  
  // Relationships
  jobs                  Job[]
  payouts               Payout[]
  performanceTips       PerformanceTip[]
  
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
}

model Job {
  id                    String        @id @default(uuid())
  trackingNumber        String        @unique @default(cuid())
  title                 String
  description           String?
  status                JobStatus     @default(PENDING)
  paymentStatus         PaymentStatus @default(UNPAID)
  
  // Financials
  totalAmount           Int           // Cents
  subtotal              Int           // Cents
  taxAmount             Int           // Cents
  platformFee           Int           // Cents
  
  // Relationships
  companyId             String?       // Null during BROADCASTING
  company               Company?      @relation(fields: [companyId], references: [id])
  customerId            String
  
  paymentIntentId       String?       @unique
  contractId            String?       @unique
  contract              Contract?     @relation(fields: [contractId], references: [id])
  
  // Analytics
  lossReason            String?       // For REJECTED/CANCELLED
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  
  // Chat
  chatMessages          ChatMessage[]
}

model Contract {
  id                    String        @id @default(uuid())
  content               String        @db.Text
  termsAndConditions    String        @db.Text
  signatureClient       String?
  signatureProvider     String?
  signedAt              DateTime?
  
  job                   Job?
  createdAt             DateTime      @default(now())
}

model ChatMessage {
  id                    String        @id @default(uuid())
  jobId                 String
  job                   Job           @relation(fields: [jobId], references: [id])
  senderId              String
  text                  String        @db.Text
  isModerated           Boolean       @default(false)
  moderationReason      String?       // e.g., "Phone number detected"
  
  createdAt             DateTime      @default(now())
}

model Transaction {
  id                    String        @id @default(uuid())
  trackingNumber        String
  stripePaymentIntentId String?       @unique
  amount                Int
  currency              String        @default("cad")
  type                  TransactionType
  status                String
  
  metadata              Json?
  
  createdAt             DateTime      @default(now())
}

model Payout {
  id                    String        @id @default(uuid())
  amount                Int
  status                String
  stripePayoutId        String?
  
  companyId             String
  company               Company       @relation(fields: [companyId], references: [id])
  
  createdAt             DateTime      @default(now())
}

model PerformanceTip {
  id                    String        @id @default(uuid())
  companyId             String
  company               Company       @relation(fields: [companyId], references: [id])
  message               String        @db.Text
  type                  String        // e.g., "Response Time", "Pricing"
  
  createdAt             DateTime      @default(now())
}

model Penalty {
  id                    String        @id @default(uuid())
  userId                String
  reason                String
  expiresAt             DateTime
  
  createdAt             DateTime      @default(now())
}

enum JobStatus {
  PENDING               // Just created
  BROADCASTING          // Sending to multiple providers
  WAITING_FOR_APPROVAL  // Contract sent to client
  REJECTED              // Negotiation failed
  ACTIVE                // Paid and in progress
  COMPLETED             // Done and funds disbursed
  CANCELLED             // Terminated by client/provider
  NON_CONTRACTED        // Appointment only
}

enum PaymentStatus {
  UNPAID
  AUTHORIZED
  CAPTURED
  REFUNDED
  FAILED
  AWAITING_VERIFICATION
}

enum TransactionType {
  STRIPE_CARD
  INTERAC_ETRANSFER
  MANUAL_CREDIT
}
