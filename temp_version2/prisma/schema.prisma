generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  owner
  platform_admin
  developer
  support
  finance
  customer
  provider
  staff
}

enum StaffRole {
  handyman
  finance
  adv
  career
  task_manager
  internal_manager
  hr
}

enum Status {
  active
  suspended
  pending_verification
}

model User {
  id                  String      @id @default(cuid())
  email               String      @unique
  password            String?     // nullable for OAuth users
  phone               String?
  displayName         String?
  role                UserRole    @default(customer)
  staffRole           StaffRole?
  status              Status      @default(active)
  isVerified          Boolean     @default(false)
  mfaEnabled          Boolean     @default(false)
  creditLimit         Float?      @default(0)
  currentDebt         Float?      @default(0)
  companyId           String?
  bio                 String?
  location            String?
  avatarUrl           String?
  refreshToken        String?     // for JWT refresh
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  // Relations
  ownedCompany        Company?    @relation("CompanyOwner")
  companies           CompanyUser[]
  contractsAsCustomer Contract[]  @relation("CustomerContracts")
  contractsAsProvider Contract[]  @relation("ProviderContracts")
  auditLogs           AuditLog[]
  transactions        Transaction[]
  schedules           Schedule[]
  kyc                 KYC?
  ticketsCreated      Ticket[]    @relation("TicketCreator")
  ticketsReceived     Ticket[]    @relation("TicketRecipient")
  posts               Post[]
  comments            Comment[]
  notifications       Notification[]
  chatMessages        ChatMessage[]
  requestsAsCustomer  Request[]   @relation("CustomerRequests")
  requestsAsProvider  Request[]   @relation("ProviderRequests")
  services            Service[]
  webauthnCredentials WebAuthnCredential[]
}

model WebAuthnCredential {
  id                  String   @id @default(cuid())
  userId              String
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  credentialID        String   @unique
  credentialPublicKey String
  counter             BigInt
  transports          String?  // JSON string
  createdAt           DateTime @default(now())
}

model Company {
  id                  String      @id @default(cuid())
  ownerId             String      @unique
  owner               User        @relation("CompanyOwner", fields: [ownerId], references: [id])
  name                String
  slug                String?     @unique
  slogan              String?
  about               String?
  logoUrl             String?
  coverImageUrl       String?
  licenseNumber       String?
  experienceDate      DateTime?
  address             String?
  phone               String?
  website             String?
  socialLinks         Json?
  type                String      @default("solo") // solo, business
  kycStatus           String      @default("pending") // pending, verified, rejected
  location            Json?
  members             CompanyUser[]
  transactions        Transaction[]
  schedules           Schedule[]
  b2bConnectionsA     B2BConnection[] @relation("ProviderA")
  b2bConnectionsB     B2BConnection[] @relation("ProviderB")
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
}

model CompanyUser {
  companyId String
  userId    String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@id([companyId, userId])
}

model ServiceCatalog {
  id             String   @id @default(cuid())
  name           String
  category       String
  subcategory    String?
  complianceTags String[]
}

model Category {
  id          String     @id @default(cuid())
  name        String
  parentId    String?
  parent      Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryHierarchy")
  description String?
  icon        String?
  chatRooms   ChatRoom[]
}

model Contract {
  id               String   @id @default(cuid())
  requestId        String?
  request          Request? @relation(fields: [requestId], references: [id])
  customerId       String
  customer         User     @relation("CustomerContracts", fields: [customerId], references: [id])
  providerId       String
  provider         User     @relation("ProviderContracts", fields: [providerId], references: [id])
  status           String   @default("pending")
  terms            String?
  amount           Float
  commissionAmount Float?
  paymentMethod    String   @default("platform")
  clientSigned     Boolean  @default(false)
  providerSigned   Boolean  @default(false)
  clientSignedAt   DateTime?
  providerSignedAt DateTime?
  checkInTime      String?
  checkOutTime     String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model AuditLog {
  id           String   @id @default(cuid())
  actorId      String?
  actor        User?    @relation(fields: [actorId], references: [id])
  action       String
  resourceType String
  resourceId   String
  timestamp    DateTime @default(now())
  metadata     Json?
}

model Transaction {
  id          String   @id @default(cuid())
  companyId   String?
  company     Company? @relation(fields: [companyId], references: [id])
  customerId  String?
  customer    User?    @relation(fields: [customerId], references: [id])
  type        String   // income, outcome
  amount      Float
  category    String?
  description String?
  timestamp   DateTime @default(now())
}

model Schedule {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  staffId   String
  staff     User     @relation(fields: [staffId], references: [id])
  taskId    String?
  startTime DateTime
  endTime   DateTime
  status    String   @default("scheduled")
}

model B2BConnection {
  id           String   @id @default(cuid())
  providerAId  String
  providerA    Company  @relation("ProviderA", fields: [providerAId], references: [id])
  providerBId  String
  providerB    Company  @relation("ProviderB", fields: [providerBId], references: [id])
  type         String   // contractor, subcontractor
  specialPrice Float?
  status       String   @default("pending")
}

model Post {
  id         String    @id @default(cuid())
  providerId String
  provider   User      @relation(fields: [providerId], references: [id])
  imageUrl   String
  caption    String?
  likes      String[]
  comments   Comment[]
  createdAt  DateTime  @default(now())
}

model Comment {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  userName  String?
  text      String
  createdAt DateTime @default(now())
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  type      String   // request, ticket, system, payment
  read      Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
}

model Service {
  id           String    @id @default(cuid())
  providerId   String
  provider     User      @relation(fields: [providerId], references: [id])
  title        String
  category     String?
  price        Float
  description  String?
  rating       Float?
  reviewsCount Int?      @default(0)
  createdAt    DateTime  @default(now())
  requests     Request[]
}

model Request {
  id         String     @id @default(cuid())
  customerId String
  customer   User       @relation("CustomerRequests", fields: [customerId], references: [id])
  providerId String
  provider   User       @relation("ProviderRequests", fields: [providerId], references: [id])
  serviceId  String
  service    Service    @relation(fields: [serviceId], references: [id])
  status     String     @default("pending")
  details    String?
  contracts  Contract[]
  createdAt  DateTime   @default(now())
}

model KYC {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // personal, business
  status    String   @default("pending")
  details   Json?
  createdAt DateTime @default(now())
}

model Ticket {
  id          String   @id @default(cuid())
  creatorId   String
  creator     User     @relation("TicketCreator", fields: [creatorId], references: [id])
  recipientId String?
  recipient   User?    @relation("TicketRecipient", fields: [recipientId], references: [id])
  type        String   // client_to_provider, client_to_admin
  subject     String
  status      String   @default("open")
  messages    Json?
  createdAt   DateTime @default(now())
}

model ChatRoom {
  id            String        @id @default(cuid())
  categoryId    String?
  category      Category?     @relation(fields: [categoryId], references: [id])
  name          String
  lastMessage   String?
  lastMessageAt DateTime?
  messages      ChatMessage[]
}

model ChatMessage {
  id         String   @id @default(cuid())
  roomId     String
  room       ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  senderId   String
  sender     User     @relation(fields: [senderId], references: [id])
  senderName String?
  senderRole String?
  text       String
  timestamp  DateTime @default(now())
}

model LegalPolicy {
  id        String   @id @default(cuid())
  title     String
  content   String
  version   String?
  updatedAt DateTime @default(now())
}

model Page {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  content   String
  status    String   @default("draft")
  lastEdit  DateTime @default(now())
}

model SystemConfig {
  id                 String   @id @default(cuid())
  key                String   @unique @default("global")
  taxRate            Float?
  commissionRate     Float?
  defaultCreditLimit Float?
  paymentMethods     String[]
  integrations       Json?
  monitoringUrls     Json?
  theme              Json?
  updatedAt          DateTime @default(now())
}
