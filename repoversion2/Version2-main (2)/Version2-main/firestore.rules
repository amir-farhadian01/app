rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isHardcodedOwner() {
      return isAuthenticated() && request.auth.token.email == "amirfarhadian569@gmail.com";
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isOwner() {
      return isHardcodedOwner() || (isAuthenticated() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().get('role', '') == 'owner');
    }

    function isAdmin() {
      return isHardcodedOwner() || (isAuthenticated() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().get('role', '') in ['owner', 'platform_admin']);
    }

    function isStaff() {
      return isAuthenticated() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (
        isAdmin() || 
        getUserData().get('role', '') in ['support', 'finance', 'operations']
      );
    }

    // Default Deny Case
    match /{document=**} {
      allow read, write: if false;
    }

    // User Rules
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isAuthenticated() && (
        request.auth.uid == userId || isAdmin()
      );
      allow delete: if isAdmin();
    }

    // Provider Service Rules (Formerly Services)
    match /provider_services/{serviceId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (resource.data.providerId == request.auth.uid || isAdmin());
      allow delete: if isAuthenticated() && (resource.data.providerId == request.auth.uid || isAdmin());
    }

    // Service Rules (Taxonomy & Provider Services)
    match /services/{serviceId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && (resource.data.providerId == request.auth.uid || isAdmin());
    }

    // Service Request Rules
    match /service_requests/{requestId} {
      allow read: if isAuthenticated() && (resource.data.providerId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Request Rules
    match /requests/{requestId} {
      allow read: if isAuthenticated() && (resource.data.customerId == request.auth.uid || resource.data.providerId == request.auth.uid || isStaff());
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (resource.data.customerId == request.auth.uid || resource.data.providerId == request.auth.uid || isStaff());
      allow delete: if isAuthenticated() && (resource.data.customerId == request.auth.uid || isStaff());
    }

    // Company Rules
    match /companies/{companyId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (resource.data.ownerId == request.auth.uid || isAdmin());
    }

    // Catalog Rules
    match /catalog/{itemId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Contract Rules
    match /contracts/{contractId} {
      allow read: if isAuthenticated() && (resource.data.customerId == request.auth.uid || resource.data.providerId == request.auth.uid || isStaff());
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        (resource.data.customerId == request.auth.uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['clientSigned', 'clientSignedAt', 'status', 'paymentMethod'])) ||
        (resource.data.providerId == request.auth.uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['providerSigned', 'providerSignedAt', 'status', 'completedAt', 'checkInTime', 'checkOutTime'])) ||
        isStaff()
      );
    }

    // Audit Logs
    match /audit_logs/{logId} {
      allow read: if isAdmin();
      allow create: if true; // Allow logging even for unauthenticated errors
      allow update, delete: if false;
    }

    // KYC Rules
    match /kyc/{kycId} {
      allow read: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      allow create: if isAuthenticated(); // Simpler create for troubleshooting
      allow update: if isAuthenticated() && (
        isAdmin() || 
        (resource.data.userId == request.auth.uid && request.resource.data.status == 'pending')
      );
      allow delete: if isAdmin();
    }

    // Ticket Rules
    match /tickets/{ticketId} {
      allow read: if isAuthenticated() && (
        resource.data.creatorId == request.auth.uid || 
        resource.data.recipientId == request.auth.uid || 
        isAdmin()
      );
      allow create: if isAuthenticated() && request.resource.data.creatorId == request.auth.uid;
      allow update: if isAuthenticated() && (
        resource.data.creatorId == request.auth.uid || 
        resource.data.recipientId == request.auth.uid || 
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    // Transaction Rules
    match /transactions/{transactionId} {
      allow read: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || 
        resource.data.customerId == request.auth.uid || 
        resource.data.providerId == request.auth.uid || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().companyId == resource.data.companyId) || 
        isAdmin()
      );
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }

    // Schedule Rules
    match /schedules/{scheduleId} {
      allow read: if isAuthenticated() && (
        resource.data.creatorId == request.auth.uid ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().companyId == resource.data.companyId) || 
        isAdmin()
      );
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        resource.data.creatorId == request.auth.uid ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().companyId == resource.data.companyId) || 
        isAdmin()
      );
      allow delete: if isAuthenticated() && (
        resource.data.creatorId == request.auth.uid ||
        isAdmin()
      );
    }

    // B2B Connection Rules
    match /b2b_connections/{connectionId} {
      allow read: if isAuthenticated() && (
        resource.data.providerAId == request.auth.uid || 
        resource.data.providerBId == request.auth.uid || 
        isAdmin()
      );
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        resource.data.providerAId == request.auth.uid || 
        resource.data.providerBId == request.auth.uid || 
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    // Post Rules
    match /posts/{postId} {
      allow read: if true;
      allow create: if isAuthenticated() && getUserData() != null && getUserData().get('role', '') == 'provider';
      allow update: if isAuthenticated() && (resource.data.providerId == request.auth.uid || isAdmin());
      allow delete: if isAuthenticated() && (resource.data.providerId == request.auth.uid || isAdmin());
    }

    // Comment Rules
    match /comments/{commentId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // Notification Rules
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated(); // Allow system or other users to trigger notifications
      allow update: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // Legal Policy Rules
    match /legal_policies/{policyId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // System Config Rules
    match /system_config/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Page Rules
    match /pages/{pageId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // CMS Visual Elements
    match /cms_visual_elements/{elementId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Chat Room Rules
    match /chat_rooms/{roomId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // Chat Message Rules
    match /chat_messages/{messageId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.senderId == request.auth.uid;
      allow update: if isAuthenticated() && (resource.data.senderId == request.auth.uid || isAdmin());
      allow delete: if isAuthenticated() && (resource.data.senderId == request.auth.uid || isAdmin());
    }
  }
}
