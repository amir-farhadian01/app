# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Google Maps API Key for Address Autocomplete
VITE_GOOGLE_MAPS_API_KEY=
# Server-side key (also set in Admin → SystemConfig.integrations.googleMaps) for /api/places and geocoding
GOOGLE_MAPS_SERVER_API_KEY=
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Local Node (`npm run dev`) — 8080 is often taken on Windows (Traefik/Docker); use 8077 for API.
PORT=8077
# Must match PORT — used for redirects from the admin-only port back to the customer app.
VITE_APP_PORT=8077
# Admin host port (Node serves the same React `App` on this port). Must differ from PORT.
ADMIN_PORT=9090
# Must match ADMIN_PORT — used by the browser to turn off main header/footer (Vite inlines it).
VITE_ADMIN_PORT=9090
# Optional: force upload/media URLs (paths like /uploads/...) to this origin when admin runs on another port.
# Example: VITE_API_PUBLIC_ORIGIN=http://localhost:8077
# VITE_API_PUBLIC_ORIGIN=

# Main app DB
DB_USER=postgres
DB_PASSWORD=EagleRock901
DB_NAME=neighborly_db
DATABASE_URL=postgresql://postgres:EagleRock901@postgres:5432/neighborly_db?schema=public

# Dedicated media metadata DB
MEDIA_DB_USER=postgres
MEDIA_DB_PASSWORD=EagleRock901
MEDIA_DB_NAME=media_db
MEDIA_DATABASE_URL=postgresql://postgres:EagleRock901@postgres-media:5432/media_db

# Object storage (video/image files)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123

# Optional auth/integrations
JWT_SECRET=replace-this-in-production
GOOGLE_CLIENT_ID=
VITE_GOOGLE_CLIENT_ID=

# Sprint J matching controls
ROUND_ROBIN_WINDOW_HOURS=24
ROUND_ROBIN_POOL_SIZE=5
