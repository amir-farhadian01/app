{
  "entities": {
    "User": {
      "title": "User",
      "description": "Core identity and profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "displayName": { "type": "string" },
        "bio": { "type": "string" },
        "gender": { "type": "string", "enum": ["male", "female", "other", "prefer_not_to_say"] },
        "dob": { "type": "string", "format": "date" },
        "address": {
          "type": "object",
          "properties": {
            "street": { "type": "string" },
            "city": { "type": "string" },
            "zip": { "type": "string" }
          }
        },
        "emergencyContact": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "phone": { "type": "string" }
          }
        },
        "role": { "type": "string", "enum": ["owner", "platform_admin", "developer", "support", "finance", "customer", "provider", "staff"] },
        "staffRole": { "type": "string", "enum": ["handyman", "finance", "adv", "career", "task_manager", "internal_manager", "hr"] },
        "status": { "type": "string", "enum": ["active", "suspended", "pending_verification"] },
        "isVerified": { "type": "boolean" },
        "requestedProviderRole": { "type": "boolean", "description": "Flag for users who applied to become providers" },
        "mfaEnabled": { "type": "boolean" },
        "creditLimit": { "type": "number", "description": "Max debt allowed for provider" },
        "currentDebt": { "type": "number", "description": "Current commission owed to platform" },
        "companyId": { "type": "string", "description": "Optional link to a company" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role", "status"]
    },
    "Company": {
      "title": "Company",
      "description": "Business entity for providers or B2B customers",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "ownerId": { "type": "string" },
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "slogan": { "type": "string" },
        "about": { "type": "string" },
        "logoUrl": { "type": "string" },
        "coverImageUrl": { "type": "string" },
        "licenseNumber": { "type": "string" },
        "experienceDate": { "type": "string", "format": "date" },
        "address": { "type": "string" },
        "phone": { "type": "string" },
        "website": { "type": "string" },
        "socialLinks": {
          "type": "object",
          "properties": {
            "instagram": { "type": "string" },
            "facebook": { "type": "string" },
            "twitter": { "type": "string" },
            "linkedin": { "type": "string" }
          }
        },
        "type": { "type": "string", "enum": ["solo", "business"] },
        "kycStatus": { "type": "string", "enum": ["pending", "verified", "rejected"] },
        "location": { "type": "object" },
        "members": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["ownerId", "name", "type"]
    },
    "ServiceCatalog": {
      "title": "Service Catalog",
      "description": "System-wide taxonomy of services",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "subcategory": { "type": "string" },
        "complianceTags": { "type": "array", "items": { "type": "string" } }
      }
    },
    "Contract": {
      "title": "Contract",
      "description": "Formal agreement between customer and provider",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "requestId": { "type": "string" },
        "customerId": { "type": "string" },
        "providerId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "started", "completed", "cancelled", "disputed"] },
        "terms": { "type": "string" },
        "amount": { "type": "number" },
        "commissionAmount": { "type": "number" },
        "paymentMethod": { "type": "string", "enum": ["platform", "cash"] },
        "clientSigned": { "type": "boolean" },
        "providerSigned": { "type": "boolean" },
        "clientSignedAt": { "type": "string", "format": "date-time" },
        "providerSignedAt": { "type": "string", "format": "date-time" },
        "checkInTime": { "type": "string" },
        "checkOutTime": { "type": "string" }
      }
    },
    "AuditLog": {
      "title": "Audit Log",
      "description": "Immutable record of system actions",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "actorId": { "type": "string" },
        "action": { "type": "string" },
        "resourceType": { "type": "string" },
        "resourceId": { "type": "string" },
        "timestamp": { "type": "string" },
        "metadata": { "type": "object" }
      }
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Financial record for income and outcome",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "companyId": { "type": "string", "description": "Provider company ID" },
        "customerId": { "type": "string", "description": "Customer user ID" },
        "type": { "type": "string", "enum": ["income", "outcome"] },
        "amount": { "type": "number" },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "amount", "timestamp"]
    },
    "Schedule": {
      "title": "Schedule",
      "description": "Task scheduling for staff",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "companyId": { "type": "string" },
        "staffId": { "type": "string" },
        "taskId": { "type": "string" },
        "startTime": { "type": "string", "format": "date-time" },
        "endTime": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["scheduled", "completed", "cancelled"] }
      },
      "required": ["companyId", "staffId", "startTime", "endTime"]
    },
    "B2BConnection": {
      "title": "B2B Connection",
      "description": "Partnership between providers",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "providerAId": { "type": "string" },
        "providerBId": { "type": "string" },
        "type": { "type": "string", "enum": ["contractor", "subcontractor"] },
        "specialPrice": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "active", "terminated"] }
      },
      "required": ["providerAId", "providerBId", "type", "status"]
    },
    "Post": {
      "title": "Post",
      "description": "Social media post for the Explorer feed",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "providerId": { "type": "string" },
        "imageUrl": { "type": "string" },
        "caption": { "type": "string" },
        "likes": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["providerId", "imageUrl", "createdAt"]
    },
    "Comment": {
      "title": "Comment",
      "description": "User comment on a post",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "postId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["postId", "userId", "text", "createdAt"]
    },
    "Notification": {
      "title": "Notification",
      "description": "System or user-triggered notification",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["request", "ticket", "system", "payment"] },
        "read": { "type": "boolean" },
        "link": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "message", "read", "createdAt"]
    },
    "ProviderService": {
      "title": "Provider Service",
      "description": "A service offered by a provider",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "providerId": { "type": "string" },
        "title": { "type": "string" },
        "serviceId": { "type": "string", "description": "Link to the Service taxonomy" },
        "price": { "type": "number" },
        "description": { "type": "string" },
        "rating": { "type": "number" },
        "reviewsCount": { "type": "integer" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Request": {
      "title": "Request",
      "description": "A service request from a customer",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customerId": { "type": "string" },
        "providerId": { "type": "string" },
        "serviceId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "accepted", "declined", "completed"] },
        "details": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "KYC": {
      "title": "KYC",
      "description": "Identity verification for users and businesses",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["personal", "business"] },
        "status": { "type": "string", "enum": ["pending", "verified", "rejected"] },
        "details": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "type", "status"]
    },
    "Ticket": {
      "title": "Ticket",
      "description": "Communication channel for support and disputes",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "creatorId": { "type": "string" },
        "recipientId": { "type": "string", "description": "Provider ID or 'admin'" },
        "type": { "type": "string", "enum": ["client_to_provider", "client_to_admin"] },
        "subject": { "type": "string" },
        "status": { "type": "string", "enum": ["open", "in_progress", "closed"] },
        "messages": { 
          "type": "array", 
          "items": { 
            "type": "object",
            "properties": {
              "senderId": { "type": "string" },
              "text": { "type": "string" },
              "timestamp": { "type": "string", "format": "date-time" }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["creatorId", "recipientId", "type", "subject", "status"]
    },
    "Service": {
      "title": "Service",
      "description": "Service taxonomy (categories and subcategories)",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "parentId": { "type": "string", "description": "ID of the parent service if this is a sub-service" },
        "level": { "type": "integer", "description": "Hierarchy level (1-5)" },
        "description": { "type": "string" },
        "icon": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "hidden", "restricted"], "description": "active=live, hidden=not in list, restricted=no new registrations" }
      },
      "required": ["name", "level"]
    },
    "ServiceRequest": {
      "title": "Service Request",
      "description": "Provider request for a new service definition",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "providerId": { "type": "string" },
        "suggestedName": { "type": "string" },
        "suggestedParentId": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["providerId", "suggestedName", "status"]
    },
    "ChatRoom": {
      "title": "Chat Room",
      "description": "Group chat room for a specific category",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "categoryId": { "type": "string" },
        "name": { "type": "string" },
        "lastMessage": { "type": "string" },
        "lastMessageAt": { "type": "string", "format": "date-time" }
      }
    },
    "ChatMessage": {
      "title": "Chat Message",
      "description": "A message within a chat room",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "roomId": { "type": "string" },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "senderRole": { "type": "string" },
        "text": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["roomId", "senderId", "text", "timestamp"]
    },
    "LegalPolicy": {
      "title": "Legal Policy",
      "description": "Terms and Conditions, Privacy Policy, etc.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "version": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "content"]
    },
    "Appointment": {
      "title": "Appointment",
      "description": "Scheduled appointment for a service",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "companyId": { "type": "string" },
        "providerId": { "type": "string" },
        "customerId": { "type": "string" },
        "serviceId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "startTime": { "type": "string", "format": "date-time" },
        "endTime": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["scheduled", "confirmed", "cancelled", "completed"] },
        "location": { "type": "string" },
        "externalId": { "type": "string", "description": "Google Calendar Event ID if synced" }
      },
      "required": ["companyId", "startTime", "endTime", "title"]
    },
    "Page": {
      "title": "Page",
      "description": "Custom CMS pages",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "slug": { "type": "string" },
        "content": { "type": "string" },
        "status": { "type": "string", "enum": ["published", "draft"] },
        "lastEdit": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "slug", "content", "status"]
    },
    "SystemConfig": {
      "title": "System Configuration",
      "description": "Global settings, tax, and integration keys",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "taxRate": { "type": "number" },
        "commissionRate": { "type": "number", "description": "Default platform commission percentage" },
        "defaultCreditLimit": { "type": "number", "description": "Initial credit limit for new providers" },
        "paymentMethods": { "type": "array", "items": { "type": "string" } },
        "integrations": {
          "type": "object",
          "properties": {
            "googleKey": { "type": "string" },
            "jwtSecret": { "type": "string" },
            "thirdPartyApis": { "type": "object" }
          }
        },
        "monitoringUrls": {
          "type": "object",
          "properties": {
            "grafana": { "type": "string" },
            "metabase": { "type": "string" },
            "portainer": { "type": "string" }
          }
        }
      }
    }
  },
  "firestore": {
    "/users/{userId}": { "schema": "User", "description": "User profiles and roles" },
    "/companies/{companyId}": { "schema": "Company", "description": "Business entities" },
    "/catalog/{itemId}": { "schema": "ServiceCatalog", "description": "Service taxonomy" },
    "/contracts/{contractId}": { "schema": "Contract", "description": "Service agreements" },
    "/audit_logs/{logId}": { "schema": "AuditLog", "description": "Security audit trail" },
    "/services/{serviceId}": { "schema": "Service", "description": "Service taxonomy" },
    "/provider_services/{serviceId}": { "schema": "ProviderService", "description": "Provider services" },
    "/service_requests/{requestId}": { "schema": "ServiceRequest", "description": "New service suggestions" },
    "/requests/{requestId}": { "schema": "Request", "description": "Customer requests" },
    "/kyc/{kycId}": { "schema": "KYC", "description": "KYC submissions" },
    "/tickets/{ticketId}": { "schema": "Ticket", "description": "Support tickets" },
    "/transactions/{transactionId}": { "schema": "Transaction", "description": "Financial records" },
    "/schedules/{scheduleId}": { "schema": "Schedule", "description": "Staff schedules" },
    "/b2b_connections/{connectionId}": { "schema": "B2BConnection", "description": "Provider partnerships" },
    "/service_taxonomy/{serviceId}": { "schema": "Service", "description": "Service taxonomy" },
    "/legal_policies/{policyId}": { "schema": "LegalPolicy", "description": "Terms and conditions" },
    "/system_config/{configId}": { "schema": "SystemConfig", "description": "Global settings" },
    "/pages/{pageId}": { "schema": "Page", "description": "Custom CMS pages" },
    "/chat_rooms/{roomId}": { "schema": "ChatRoom", "description": "Category group chats" },
    "/chat_messages/{messageId}": { "schema": "ChatMessage", "description": "Messages in rooms" }
  }
}
